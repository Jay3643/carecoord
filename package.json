{
  "name": "carecoord",
  "version": "1.0.0",
  "description": "Regional Care Coordination Messaging Overlay",
  "private": true,
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install",
    "dev": "concurrently -n server,client -c blue,green \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && node index.js",
    "seed": "cd server && node seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.3",
    "speakeasy": "^2.0.0"
  }
}
