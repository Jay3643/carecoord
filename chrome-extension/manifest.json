{
  "manifest_version": 3,
  "name": "Seniority Connect",
  "version": "1.0.0",
  "description": "Care coordination copilot for Practice Fusion — syncs patient data with Seniority Connect",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.practicefusion.com/*",
    "https://www.practicefusion.com/*",
    "https://app.practicefusion.com/*",
    "https://static.practicefusion.com/*",
    "http://localhost:3001/*",
    "https://carecoord-o3en.onrender.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.practicefusion.com/*",
        "https://app.practicefusion.com/*",
        "https://static.practicefusion.com/*",
        "https://*.practicefusion.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Seniority Connect"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
